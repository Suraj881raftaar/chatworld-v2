# ==============================================================================
# Chat World v2 - Environment Variables Configuration
# ==============================================================================

# Core Settings
ENVIRONMENT=production
PROJECT_NAME="Chat World v2"

# Security Configurations
# IMPORTANT: Generate secure, random 64-character strings for these variables
SECRET_KEY=your-secret-key
JWT_SECRET=your-jwt-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configurations
DATABASE_URL=postgresql+asyncpg://username:password@host/database
REDIS_URL=redis://localhost:6379/0

# CORS Allowed Origins
CORS_ORIGINS=http://localhost:5173
