# ==============================================================================
# Chat World v2 - Environment Variables Configuration
# ==============================================================================

# Core Settings
ENVIRONMENT=development
PROJECT_NAME="Chat World v2"

# Security Configurations
# IMPORTANT: Replace with a secure, random 64-character string in production
SECRET_KEY=super_secret_temporary_key_for_development_purposes_only
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configurations
# Local Development (defaults to SQLite in repository root if left empty)
DATABASE_URL=sqlite+aiosqlite:///chatworld.db

# Production (PostgreSQL Async schema)
# DATABASE_URL=postgresql+asyncpg://chatuser:chatpassword@localhost:5432/chatdb

# Cache & Message Broker (Redis pub/sub)
# Local development falls back to local in-memory pub/sub if Redis is offline
REDIS_URL=redis://localhost:6379/0

# CORS Allowed Origins (Comma-separated or JSON list format)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
